# QueueStorm Investigator — example env file.
# Copy to `.env` (which is git-ignored) and fill in real values.
# NEVER commit real secrets. This file lists NAMES ONLY (AC-13).

# --- LLM layer (optional; rule-based engine is the default brain) ---
LLM_ENABLED=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=
MODEL_NAME=gemini-2.0-flash

# --- HTTP server ---
PORT=8000
