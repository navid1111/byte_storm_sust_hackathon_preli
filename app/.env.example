# QueueStorm Investigator — environment variables
# Variable NAMES only — no real values are committed.
# Copy this file to `.env` and fill in real values for local dev only.
# `.env` is git-ignored. Never commit a populated `.env`.

# --- LLM layer (optional) ---
# The LLM AUTO-ENABLES when GEMINI_API_KEY is set. On a deployed host (e.g.
# Render) just add GEMINI_API_KEY in the platform's Environment settings —
# no .env file needed there. No key => safe rule-based fallback.
# Set LLM_ENABLED=false to force it off even when a key is present.
GEMINI_API_KEY=
LLM_PROVIDER=gemini
MODEL_NAME=gemini-2.0-flash
# LLM_ENABLED=false   # uncomment to force-disable

# --- HTTP server ---
PORT=8000

# --- Request handling ---
REQUEST_TIMEOUT_SECONDS=25
