# QueueStorm Investigator — environment variables
# Variable NAMES only — no real values are committed.
# Copy this file to `.env` and fill in real values for local dev only.
# `.env` is git-ignored. Never commit a populated `.env`.

# --- LLM layer (optional, default OFF) ---
LLM_ENABLED=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=
MODEL_NAME=gemini-1.5-flash

# --- HTTP server ---
PORT=8000

# --- Request handling ---
REQUEST_TIMEOUT_SECONDS=25
